{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "lib": ["ESNext", "DOM"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "smocky": ["./src/index.ts"],
      "smocky/types": ["./src/types.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*.ts", "helpers/**/*.ts", "endpoints/**/*.ts", "smocky.config.ts"]
}
