{
  "name": "smocker",
  "version": "0.1.0",
  "description": "Convention-over-configuration mock server for Bun.",
  "type": "module",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "smocker": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts serve",
    "start": "bun run src/index.ts serve",
    "record": "RECORD=1 bun run src/index.ts serve",
    "check:api": "bun run src/index.ts check api",
    "check:mocks": "bun run src/index.ts check mocks",
    "check:all": "bun run src/index.ts check all",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
